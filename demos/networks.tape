# Network management demo
Output ../assets/demo-networks.gif

Set Theme "Catppuccin Mocha"
Set Width 1200
Set Height 600
Set FontSize 14
Set Padding 10
Set TypingSpeed 50ms

Type "go run ./cmd"
Enter
Sleep 3s

# Switch to networks tab
Type "4"
Sleep 2s

# Navigate through network list
Type "j"
Sleep 500ms
Type "j"
Sleep 500ms
Type "k"
Sleep 500ms

# Inspect a network
Type "i"
Sleep 2s
Type "q"
Sleep 1s

# Quit
Type "q"
Sleep 500ms
